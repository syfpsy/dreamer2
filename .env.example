# Dreamer2 runtime configuration.
# Copy to .env.local (git-ignored) and fill in real values.

# Optional: where the runtime persists state.
# In serverless deploys this defaults to /tmp/dreamer2-state.
# DREAMER2_STATE_DIR=./state

# Optional: force a specific provider. Leave unset to auto-pick
# based on available keys. Allowed: deepseek
# DREAMER2_PROVIDER=deepseek

# DeepSeek API (OpenAI-compatible endpoint at api.deepseek.com).
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
