{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dreamer2/packs/portrait-pack.schema.json",
  "title": "Portrait Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "creativeDirection",
    "defaultThemeId",
    "supportedSlots",
    "defaults",
    "states",
    "partRefs"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "creativeDirection": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "defaultThemeId": {
      "type": "string"
    },
    "supportedSlots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "states": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "partRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
