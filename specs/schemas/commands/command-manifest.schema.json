{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dreamer2/commands/command-manifest.schema.json",
  "title": "Command Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "domain",
    "verb",
    "summary",
    "handlerRef",
    "availability",
    "effects"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "verb": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "handlerRef": {
      "type": "string"
    },
    "availability": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shell",
        "mind",
        "memory"
      ],
      "properties": {
        "shell": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mind": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "memory": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "arguments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "required"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
